# vcstool manifest for the Jazzy workspace.
# Copy this to  ws/jazzy/project.repos  and edit, then:  make import DISTRO=jazzy
#
# The KISS-ICP ROS 2 wrapper as a source package (built with colcon / `cb`).
repositories:
  kiss-icp:
    type: git
    url: https://github.com/PRBonn/kiss-icp.git
    version: main
