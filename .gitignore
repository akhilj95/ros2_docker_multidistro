# ==============================================================================
# What must NOT go into version control.
# ==============================================================================

# ---- Machine-specific / generated ----
.env

# ---- Data: bags, maps, calibrations. Keep the folder, ignore its contents ----
# (data/.gitkeep stays tracked so the bind-mount target exists on a fresh clone)
data/*
!data/.gitkeep

# ---- colcon build artifacts (per-distro workspaces) ----
ws/*/build/
ws/*/install/
ws/*/log/
compile_commands.json

# ---- rosbag files, wherever they land ----
*.bag
*.mcap
*.db3
*.db3-shm
*.db3-wal

# ---- Editor / IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
# To share specific VS Code settings, force-track them, e.g.:
# !.vscode/settings.json

# ---- Python ----
__pycache__/
*.py[cod]
.venv/
venv/

# ---- OS ----
.DS_Store
Thumbs.db